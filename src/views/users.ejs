<h1>Usuários</h1>

<a href="/users/new">Novo Usuário</a>

<table>

<tr>
<th>Nome</th>
<th>Email</th>
<th>Ações</th>
</tr>

<% users.forEach(user => { %>

<tr>

<td><%= user.name %></td>
<td><%= user.email %></td>

<td>

<a href="/users/edit/<%= user.id %>">Editar</a>

<a href="/users/delete/<%= user.id %>">Excluir</a>

</td>

</tr>

<% }) %>

</table>
