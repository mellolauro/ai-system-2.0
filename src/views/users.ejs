<div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-slate-800">Gerenciar Usuários</h1>
    <a href="/users/new" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg font-medium transition-all shadow-md flex items-center gap-2">
        <i class="fas fa-user-plus"></i> Novo Usuário
    </a>
</div>

<div class="bg-white rounded-xl shadow-sm overflow-hidden border border-slate-200">
    <table class="w-full text-left border-collapse">
        <thead class="bg-slate-50">
            <tr>
                <th class="p-4 font-semibold text-slate-600 border-b">Nome / Email</th>
                <th class="p-4 font-semibold text-slate-600 border-b">Telegram ID</th>
                <th class="p-4 font-semibold text-slate-600 border-b">Empresa (Tenant)</th>
                <th class="p-4 font-semibold text-slate-600 border-b text-center">Ações</th>
            </tr>
        </thead>
        <tbody>
            <% users.forEach(user => { %>
                <tr class="hover:bg-slate-50 transition-colors border-b last:border-0">
                    <td class="p-4">
                        <div class="font-bold text-slate-700"><%= user.name %></div>
                        <div class="text-xs text-slate-400"><%= user.email || 'Sem email' %></div>
                    </td>
                    <td class="p-4 text-slate-600">
                        <span class="bg-sky-50 text-sky-700 px-2 py-1 rounded border border-sky-100 text-sm font-mono">
                            <i class="fab fa-telegram-plane mr-1"></i><%= user.telegramId %>
                        </span>
                    </td>
                    <td class="p-4">
                        <span class="text-sm font-medium text-slate-600 bg-slate-100 px-3 py-1 rounded-full">
                            <%= user.tenant ? user.tenant.name : 'Nenhum' %>
                        </span>
                    </td>
                    <td class="p-4 text-center space-x-3">
                        <a href="/users/edit/<%= user.id %>" class="text-blue-500 hover:text-blue-700 transition-colors">
                            <i class="fas fa-user-edit"></i>
                        </a>
                        <button onclick="confirmUserDelete('<%= user.id %>')" class="text-red-400 hover:text-red-600 transition-colors">
                            <i class="fas fa-trash-alt"></i>
                        </button>
                    </td>
                </tr>
            <% }) %>
        </tbody>
    </table>
</div>

<script>
    function confirmUserDelete(id) {
        if(confirm('Deseja realmente remover este usuário do sistema?')) {
            window.location.href = `/users/delete/${id}`;
        }
    }
</script>
