<div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-slate-800">Catálogo de Produtos</h1>
    <a href="/products/new" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg font-medium transition-all shadow-md flex items-center gap-2">
        <i class="fas fa-plus"></i> Novo Produto
    </a>
</div>

<div class="bg-white rounded-xl shadow-sm overflow-hidden border border-slate-200">
    <table class="w-full text-left border-collapse">
        <thead class="bg-slate-50">
            <tr>
                <th class="p-4 font-semibold text-slate-600 border-b">Produto</th>
                <th class="p-4 font-semibold text-slate-600 border-b">Preço</th>
                <th class="p-4 font-semibold text-slate-600 border-b">Estoque</th>
                <th class="p-4 font-semibold text-slate-600 border-b">Ações</th>
            </tr>
        </thead>
        <tbody>
            <% products.forEach(p => { %>
                <tr class="hover:bg-slate-50 transition-colors border-b last:border-0">
                    <td class="p-4 flex items-center gap-4">
                        <div class="w-12 h-12 rounded-lg bg-slate-100 overflow-hidden border">
                            <% if (p.images.length) { %>
                                <img src="<%= p.images[0].url %>" class="w-full h-full object-cover">
                            <% } else { %>
                                <div class="w-full h-full flex items-center justify-center text-slate-400 text-xs">Sem foto</div>
                            <% } %>
                        </div>
                        <span class="font-medium text-slate-700"><%= p.name %></span>
                    </td>
                    <td class="p-4 text-slate-600 font-semibold">R$ <%= p.price.toLocaleString('pt-BR', {minimumFractionDigits: 2}) %></td>
                    <td class="p-4">
                        <span class="px-3 py-1 rounded-full text-xs font-bold <%= p.stock > 5 ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700' %>">
                            <%= p.stock %> unidades
                        </span>
                    </td>
                    <td class="p-4">
                        <button class="text-slate-400 hover:text-blue-600 transition-colors"><i class="fas fa-edit"></i></button>
                    </td>
                </tr>
            <% }) %>
        </tbody>
    </table>
</div>
