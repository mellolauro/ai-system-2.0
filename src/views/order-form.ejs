<div class="max-w-5xl mx-auto">
    <div class="mb-6">
        <a href="/orders" class="text-blue-600 text-sm hover:underline"><i class="fas fa-arrow-left"></i> Voltar</a>
        <h1 class="text-2xl font-bold text-slate-800 mt-2">Registrar Novo Pedido</h1>
    </div>

    <form action="/orders/create" method="POST" class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="lg:col-span-2 space-y-6">
            <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-200">
                <div class="flex justify-between items-center mb-6">
                    <h2 class="text-sm font-bold uppercase text-slate-400 tracking-wider">Itens do Pedido</h2>
                    <button type="button" onclick="addItem()" class="text-blue-600 hover:text-blue-800 text-sm font-bold">
                        <i class="fas fa-plus-circle"></i> Adicionar Item
                    </button>
                </div>
                
                <div id="order-items" class="space-y-4">
                    <div class="item-row flex gap-4 items-end pb-4 border-b border-slate-50">
                        <div class="flex-1">
                            <label class="block text-[10px] font-bold text-slate-400 uppercase mb-1">Produto</label>
                            <select name="products[]" onchange="updateTotal()" class="product-select w-full p-2.5 bg-slate-50 border border-slate-200 rounded-lg outline-none focus:ring-2 focus:ring-blue-500">
                                <option value="" data-price="0">Selecione...</option>
                                <% products.forEach(p => { %>
                                    <option value="<%= p.id %>" data-price="<%= p.price %>"><%= p.name %> - R$ <%= p.price.toLocaleString('pt-BR') %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="w-24">
                            <label class="block text-[10px] font-bold text-slate-400 uppercase mb-1">Qtd</label>
                            <input type="number" name="quantities[]" value="1" min="1" oninput="updateTotal()" class="quantity-input w-full p-2.5 bg-slate-50 border border-slate-200 rounded-lg outline-none focus:ring-2 focus:ring-blue-500">
                        </div>
                        <button type="button" onclick="removeItem(this)" class="p-2.5 text-slate-300 hover:text-red-500">
                            <i class="fas fa-trash"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="space-y-6">
            <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-200 sticky top-6">
                <div class="space-y-4">
                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase mb-2">Cliente</label>
                        <select name="userId" class="w-full p-3 border rounded-lg bg-white outline-none focus:border-blue-500" required>
                            <% users.forEach(u => { %>
                                <option value="<%= u.id %>"><%= u.name %></option>
                            <% }) %>
                        <% if (users.length === 0) { %> <option disabled>Nenhum usuário encontrado</option> <% } %>
                        </select>
                    </div>

                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase mb-2">Status</label>
                        <select name="status" class="w-full p-3 border rounded-lg bg-white outline-none">
                            <option value="PENDING">Pendente</option>
                            <option value="PAID">Pago</option>
                        </select>
                    </div>

                    <div class="pt-6 border-t border-slate-100">
                        <div class="flex justify-between items-center mb-6">
                            <span class="text-slate-400 font-medium">Total do Pedido</span>
                            <span id="grand-total" class="text-2xl font-black text-slate-900">R$ 0,00</span>
                        </div>
                        <button type="submit" class="w-full bg-slate-900 hover:bg-black text-white font-bold py-4 rounded-xl transition-all shadow-lg flex items-center justify-center gap-2">
                            <i class="fas fa-check"></i> Finalizar Pedido
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<script>
    function addItem() {
        const container = document.getElementById('order-items');
        const firstRow = container.querySelector('.item-row');
        const newRow = firstRow.cloneNode(true);
        
        // Limpar os campos da nova linha
        newRow.querySelector('select').value = "";
        newRow.querySelector('input').value = 1;
        
        container.appendChild(newRow);
        updateTotal();
    }

    function removeItem(btn) {
        const rows = document.querySelectorAll('.item-row');
        if (rows.length > 1) {
            btn.closest('.item-row').remove();
            updateTotal();
        }
    }

    function updateTotal() {
        let grandTotal = 0;
        const rows = document.querySelectorAll('.item-row');
        
        rows.forEach(row => {
            const select = row.querySelector('.product-select');
            const price = parseFloat(select.options[select.selectedIndex].getAttribute('data-price')) || 0;
            const qty = parseInt(row.querySelector('.quantity-input').value) || 0;
            grandTotal += price * qty;
        });

        document.getElementById('grand-total').innerText = grandTotal.toLocaleString('pt-BR', {
            style: 'currency',
            currency: 'BRL'
        });
    }
</script>
