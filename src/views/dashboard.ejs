<h1 class="text-2xl font-bold text-slate-800 mb-8">Visão Geral</h1>

<div class="grid grid-cols-1 md:grid-cols-3 gap-6">

<div class="bg-white p-6 rounded-xl shadow-sm border border-slate-100 flex items-center justify-between">
<div>
<p class="text-sm text-slate-500 font-medium uppercase">Produtos</p>
<h3 class="text-3xl font-bold mt-1"><%= productsCount %></h3>
</div>
<div class="bg-blue-100 p-4 rounded-lg text-blue-600">
<i class="fas fa-shopping-bag fa-2x"></i>
</div>
</div>

<div class="bg-white p-6 rounded-xl shadow-sm border border-slate-100 flex items-center justify-between">
<div>
<p class="text-sm text-slate-500 font-medium uppercase">Usuários</p>
<h3 class="text-3xl font-bold mt-1"><%= usersCount %></h3>
</div>
<div class="bg-green-100 p-4 rounded-lg text-green-600">
<i class="fas fa-users fa-2x"></i>
</div>
</div>

<div class="bg-white p-6 rounded-xl shadow-sm border border-slate-100 flex items-center justify-between">
<div>
<p class="text-sm text-slate-500 font-medium uppercase">Tenants</p>
<h3 class="text-3xl font-bold mt-1"><%= tenantsCount %></h3>
</div>
<div class="bg-purple-100 p-4 rounded-lg text-purple-600">
<i class="fas fa-building fa-2x"></i>
</div>
</div>

</div>
