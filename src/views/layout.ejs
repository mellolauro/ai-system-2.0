<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI-System | Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        /* Estilo para suavizar o scroll se a página for longa */
        html { scroll-behavior: smooth; }
    </style>
</head>
<body class="bg-slate-50 text-slate-800 antialiased">
    <div class="flex min-h-screen">
        
        <aside class="w-64 bg-slate-900 text-slate-300 shadow-xl flex flex-col">
            <div class="p-6 text-2xl font-bold flex items-center gap-3 border-b border-slate-800 text-white">
                <span class="bg-blue-600 p-2 rounded-lg text-sm">🚀</span>
                <span>AI-System</span>
            </div>

            <nav class="p-4 flex-1 space-y-1">
                <p class="px-3 text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-2">Principal</p>
                
                <a href="/dashboard" class="flex items-center p-3 rounded-lg hover:bg-slate-800 hover:text-white transition-all group">
                    <i class="fas fa-chart-line mr-3 text-slate-500 group-hover:text-blue-400"></i> Dashboard
                </a>

                <p class="px-3 text-[10px] font-semibold text-slate-500 uppercase tracking-wider mt-6 mb-2">Gestão</p>

                <a href="/tenants" class="flex items-center p-3 rounded-lg hover:bg-slate-800 hover:text-white transition-all group">
                    <i class="fas fa-building mr-3 text-slate-500 group-hover:text-blue-400"></i> Tenants
                </a>

                <a href="/products" class="flex items-center p-3 rounded-lg hover:bg-slate-800 hover:text-white transition-all group">
                    <i class="fas fa-box mr-3 text-slate-500 group-hover:text-blue-400"></i> Produtos
                </a>

                <a href="/users" class="flex items-center p-3 rounded-lg hover:bg-slate-800 hover:text-white transition-all group">
                    <i class="fas fa-users mr-3 text-slate-500 group-hover:text-blue-400"></i> Usuários
                </a>
            </nav>

            <div class="p-4 border-t border-slate-800 text-[10px] text-slate-500 text-center">
                v1.0.4 - Ubuntu Server
            </div>
        </aside>

        <main class="flex-1 flex flex-col">
            <header class="bg-white shadow-sm border-b border-slate-200 p-4 flex justify-between items-center px-8">
                <div class="text-slate-400">
                    <span class="text-xs uppercase font-bold tracking-widest">Painel de Controle</span>
                </div>
                <div class="flex items-center gap-4">
                    <div class="text-right">
                        <p class="text-sm font-bold leading-none">Administrador</p>
                        <p class="text-[10px] text-green-500 font-medium italic">Online</p>
                    </div>
                    <div class="w-10 h-10 rounded-full bg-blue-600 border-2 border-blue-100 flex items-center justify-center text-white shadow-inner font-bold">
                        A
                    </div>
                </div>
            </header>

            <div class="p-8 flex-1 overflow-y-auto">
                <%- body %>
            </div>
        </main>
    </div>
</body>
</html>
