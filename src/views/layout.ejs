<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI-System | Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-slate-50 text-slate-800">
    <div class="flex min-h-screen">
        <aside class="w-64 bg-slate-900 text-white shadow-xl">
            <div class="p-6 text-2xl font-bold flex items-center gap-2 border-b border-slate-800">
                <span class="text-blue-500">🚀</span> AI-System
            </div>
            <nav class="p-4 space-y-2">

                <a href="/dashboard" class="flex items-center p-3 rounded-lg hover:bg-slate-800 transition-colors">
                    <i class="fas fa-chart-line mr-3"></i> 📊 Dashboard
                </a>

                <a href="/tenants" class="flex items-center p-3 rounded-lg hover:bg-slate-800 transition-colors">
                    <i class="fas fa-building mr-3"></i> 🏢 Tenants
                </a>

                <a href="/products" class="flex items-center p-3 rounded-lg hover:bg-slate-800 transition-colors">
                    <i class="fas fa-box mr-3"></i> 📦 Produtos
                </a>

                <a href="/users" class="flex items-center p-3 rounded-lg hover:bg-slate-800 transition-colors">
                    <i class="fas fa-users mr-3"></i> 👤 Usuários
                </a>

            </nav>
        </aside>

        <main class="flex-1">
            <header class="bg-white shadow-sm p-4 flex justify-end items-center">
                <div class="flex items-center gap-3">
                    <span class="text-sm font-medium">Administrador</span>
                    <div class="w-10 h-10 rounded-full bg-blue-600 flex items-center justify-center text-white">A</div>
                </div>
            </header>
            <div class="p-8">
                <%- body %>
            </div>
        </main>
    </div>
</body>
</html>
